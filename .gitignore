# ── Secrets — never push these ──────────────────────────────────────────────
# Real credentials: SECRET_KEY, GROQ_API_KEY, SMTP username/password, Mongo URL.
# backend/.env.example stays tracked as the template; only the real .env is ignored.
backend/.env
.env
.env.local
.env.*.local

# ── Python / backend ─────────────────────────────────────────────────────────
backend/venv/
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.pytest_cache/

# ML model binaries — regenerate locally via `python save_models.py` from the
# CSV datasets (see README) rather than committing trained artifacts.
backend/ml_models/*.pkl

# ── Node / frontend ──────────────────────────────────────────────────────────
frontend/node_modules/
frontend/dist/
frontend/.vite/
npm-debug.log*
yarn-error.log*

# ── Local tool config — machine/user-specific, not shared with the team ─────
.claude/settings.local.json
.devin/config.local.json

# ── OS / editor cruft ────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
.vscode/*
!.vscode/extensions.json
.idea/
