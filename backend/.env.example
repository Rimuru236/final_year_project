# Copy this to .env and fill in your values

# MongoDB — use localhost for local dev, "mongo" for Docker Compose
MONGODB_URL=mongodb://localhost:27017
DATABASE_NAME=studymind

# JWT — change this to a long random string in production
SECRET_KEY=change_me_to_a_long_random_secret_key_in_production

# Groq API key — required for MCQ generation, the AI Assistant chat, and
# glossary generation (optional — each falls back gracefully without it).
GROQ_API_KEY=gsk_...

# Anthropic API key — legacy field kept for compatibility; not used by any
# current feature (MCQ/chat/glossary generation all call Groq — see above).
ANTHROPIC_API_KEY=

# Model files directory (relative to backend/)
MODEL_DIR=ml_models

# CORS origins — add your frontend URL
ALLOWED_ORIGINS=["http://localhost:5173","http://localhost:3000"]

# ── Email / SMTP (Day 5) ────────────────────────────────────────────────────
# Leave SMTP_HOST blank to run in log-only mode (safe for dev — no email sent).
# For Gmail: host=smtp.gmail.com, port=587, use_tls=true, username=your@gmail.com
# For SendGrid: host=smtp.sendgrid.net, port=587, username=apikey, password=<api_key>
# For Mailgun: host=smtp.mailgun.org, port=587
# For local dev (MailHog): host=localhost, port=1025, use_tls=false
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=noreply@cognitive-sanctuary.app
SMTP_FROM_NAME=Cognitive Sanctuary
SMTP_USE_TLS=true
